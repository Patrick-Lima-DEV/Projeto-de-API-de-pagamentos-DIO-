# Configurações de Segurança
JWT_SECRET=sua_chave_secreta_aqui_mude_em_producao

# Configurações da Aplicação
DEBUG=False
LOG_LEVEL=INFO

# Configurações de CORS
ALLOW_ORIGINS=*

# Configurações de Rate Limit
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=60

